version: "3.9"

# docker-compose.yml — local development only
# Production/dev deployments are managed by ymir CLI

services:
  app:
    build: .
    ports:
      - "8000:8000"
    environment:
      - APP_ENV=local
{% for flag in flags %}
      - FEATURE_{{ flag.upper().replace('-', '_') }}=false
{% endfor %}
    volumes:
{% if primary_stack == "django" %}
      - .:/app
{% else %}
      - .:/app
{% endif %}
    command: >
{% if primary_stack == "django" %}
      python manage.py runserver 0.0.0.0:8000
{% else %}
      python main.py
{% endif %}
