# Feature flags for {{ name }}
# All flags default to OFF. Use ci_cd CLI to activate per environment.
# Injected as env vars at runtime: FEATURE_<FLAG_NAME_UPPER>=true/false

flags:
{% for flag in flags %}
  {{ flag }}:
    description: "{{ flag }} feature"
    created: "{{ today }}"
    environments:
      dev: false
      prod: false
{% else %}
  {}
{% endfor %}
