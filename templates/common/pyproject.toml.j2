[tool.poetry]
name = "{{ name.lower().replace('-', '_') }}"
version = "0.1.0"
description = "{{ description }}"
authors = ["dev <dev@localhost>"]
readme = "README.md"

[tool.poetry.dependencies]
python = "^3.12"
{% if primary_stack == "django" %}Django = ">=5.0,<6.0"
{% elif primary_stack == "flask" %}Flask = ">=3.0"
{% endif %}
[tool.poetry.group.dev.dependencies]
pytest = ">=8.0"
{% if primary_stack == "django" %}pytest-django = ">=4.8"
{% elif primary_stack == "flask" %}pytest-flask = ">=1.3"
{% endif %}pytest-bdd = ">=7.0"
ruff = ">=0.4"

[build-system]
requires = ["poetry-core"]
build-backend = "poetry.core.masonry.api"

[tool.ruff]
line-length = 88

[tool.ruff.lint]
select = ["E", "F", "I", "UP", "B", "SIM"]

[tool.pytest.ini_options]
{% if primary_stack == "django" %}DJANGO_SETTINGS_MODULE = "{{ app }}.settings"
{% endif %}python_files = ["tests/test_*.py"]
