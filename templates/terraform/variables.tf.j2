variable "deploy_host" {
  description = "Deploy server hostname or IP"
}

variable "deploy_user" {
  description = "SSH user on the deploy server"
  default     = "root"
}

variable "deploy_ssh_key" {
  description = "Path to SSH private key for the deploy server"
}

variable "project_dir" {
  description = "Absolute path to project directory"
  default     = "{{ project_dir }}"
}

variable "image_tag" {
  description = "Docker image tag"
}

variable "container_name" {
  description = "Docker container name"
}

variable "port" {
  description = "Host port to expose"
  type        = number
}

variable "environment" {
  description = "Environment name (dev, prod)"
}

{% for flag in flags %}
variable "feature_{{ flag }}" {
  description = "Feature flag: {{ flag }}"
  type        = bool
  default     = false
}
{% endfor %}
