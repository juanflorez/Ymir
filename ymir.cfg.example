# ymir.cfg — Ymir configuration
#
# Copy this file to ymir.cfg and fill in your values.
# ymir.cfg is gitignored — never commit it (it may contain SSH key paths).
#
# All values here can also be overridden with environment variables (uppercase,
# underscored). e.g. DEPLOY_HOST overrides [deploy] deploy_host.

[paths]
# Root directory where new projects are created.
projects_root = /home/you/projects

[deploy]
# SSH host for deployments (your server running Docker).
deploy_host = YOUR_SERVER_IP

# SSH user on the deployment server.
deploy_user = root

# Path to the SSH private key for the deployment server.
# Relative to home dir or absolute.
deploy_ssh_key = ~/keys/deploy.pem

# Base URL for accessing deployed services in the browser (no trailing slash).
# e.g. http://your-server-ip  or  http://your.tailscale.ip
deploy_url = http://YOUR_SERVER_URL

[ports]
# First port to allocate for dev environments.
# Each new dev env gets the next available port starting here.
dev_port_start = 8100
